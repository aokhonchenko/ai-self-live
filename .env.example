# Copy this file to .env and fill in real values.
# .env is intentionally ignored by Git.
# AI_API_KEY may be empty when the endpoint does not require authentication.
AI_API_KEY=
AI_BASE_URL=https://your-openai-compatible-endpoint.example/v1
AI_MODEL=your-model-name

# Autosession delay range, in seconds. Defaults are 5-15 minutes.
AUTO_SESSION_MIN_DELAY_SECONDS=300
AUTO_SESSION_MAX_DELAY_SECONDS=900
